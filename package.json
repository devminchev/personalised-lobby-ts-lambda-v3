{
  "name": "personalised-lobby-ts-lambda-v3",
  "author": "Nightwatch",
  "homepage": "https://gitlab.ballys.tech/excite/native/applications/personalised-lobby-ts-lambda-v3",
  "description": "The backend of the lobby 🦉🦉",
  "keywords": [
    "lobby",
    "personalised lobby",
    "aws lambda",
    "lobby backend api v3",
    "lobby backend"
  ],
  "version": "0.0.0",
  "scripts": {
    "prepare": "husky",
    "build": "nx run-many --target=build --all",
    "build:affected": "nx affected --target=build",
    "test": "nx run-many --target=test --all",
    "test:affected": "nx affected --target=test",
    "test:coverage": "nx run-many --target=test --configuration=coverage --all",
    "test:coverage:affected": "nx affected --target=test --configuration=coverage",
    "lint": "nx run-many --target=lint --all",
    "lint:affected": "nx affected --target=lint",
    "format": "nx run-many --target=format --all",
    "format:affected": "nx affected --target=format",
    "sam:build": "sam build",
    "sam:local:invoke": "sam local invoke",
    "sam:local:start-api": "sam local start-api",
    "sam:deploy": "sam deploy",
    "docker:build": "nx run-many --target=docker --all",
    "docker:build:affected": "nx affected --target=docker",
    "docker:build:production": "nx run-many --target=docker --configuration=production --all",
    "docker:push": "nx run-many --target=docker-push --all",
    "docker:push:affected": "nx affected --target=docker-push",
    "graph": "nx graph",
    "clean": "rm -rf test-output && mkdir -p .nx-tmp && cp .nx/nxw.js .nx-tmp/ && rm -rf node_modules .aws-sam dist tmp && rm -rf .nx/cache .nx/workspace-data .nx/installation && mkdir -p .nx && cp .nx-tmp/nxw.js .nx/ && rm -rf .nx-tmp && find ./functions -type d -name 'node_modules' -exec rm -rf {} + 2>/dev/null || true && find ./libs -type d -name 'node_modules' -exec rm -rf {} + 2>/dev/null || true",
    "setup": "yarn install && yarn nx reset && yarn build && mkdir test-output",
    "version": "nx release version",
    "changelog": "nx release changelog",
    "postversion": "node ./scripts/update-dependencies.js"
  },
  "private": true,
  "dependencies": {
    "@aws-sdk/credential-provider-node": "^3.569.0",
    "@contentful/node-apps-toolkit": "3.9.2",
    "@opensearch-project/opensearch": "^2.7.0",
    "aws-sdk": "^2.1615.0",
    "axios": "^1.10.0",
    "contentful-management": "^11.47.1",
    "https-proxy-agent": "^7.0.6",
    "os-client": "0.53.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@jest/globals": "^29.2.0",
    "@jscutlery/semver": "^5.6.0",
    "@nx/esbuild": "20.7.0",
    "@nx/eslint": "20.7.0",
    "@nx/eslint-plugin": "^20.7.0",
    "@nx/jest": "20.7.0",
    "@nx/js": "20.7.0",
    "@nx/node": "20.7.0",
    "@nx/workspace": "^20.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^10.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^11.0.7",
    "@types/aws-lambda": "^8.10.92",
    "@types/jest": "^29.4.0",
    "@types/nock": "^11.1.0",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "esbuild": "^0.25.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "glob": "^11.0.1",
    "husky": "^9.1.7",
    "jest": "^29.3.1",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.5.0",
    "nock": "^13.5.4",
    "nx": "20.8.0",
    "prettier": "^3.5.3",
    "semantic-release": "^21.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.12.0",
    "typescript": "~5.3.2"
  },
  "workspaces": [
    "functions/*",
    "libs/*"
  ],
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "jest-junit": {
    "outputDirectory": "test-evidence",
    "outputName": "junit",
    "uniqueOutputName": "true",
    "suiteNameTemplate": "{filepath}",
    "classNameTemplate": "{classname}",
    "titleTemplate": "{title}",
    "ancestorSeparator": " › "
  }
}
