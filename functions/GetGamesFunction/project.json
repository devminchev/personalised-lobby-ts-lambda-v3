{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "get-games",
  "sourceRoot": "functions/GetGamesFunction",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "options": {
        "outputPath": "dist/functions/GetGamesFunction",
        "main": "functions/GetGamesFunction/app.ts",
        "tsConfig": "functions/GetGamesFunction/tsconfig.json",
        "platform": "node",
        "target": "node20",
        "bundle": true,
        "sourcemap": true,
        "minify": true,
        "skipTypeCheck": false,
        "external": [
          "aws-sdk"
        ],
        "format": [
          "cjs"
        ],
        "outputFileName": "app.cjs",
        "thirdParty": true
      },
      "configurations": {
        "production": {
          "configuration": "application"
        }
      }
    },
    "test": {},
    "lint": {},
    "format": {},
    "version": {},
    "changelog": {},
    "docker": {},
    "docker-push": {},
    "run-docker": {},
    "sam-invoke-eu": {
      "options": {
        "args": [
          "--functionName=GetGamesFunction"
        ]
      }
    },
    "sam-invoke-validate-eu": {},
    "sam-invoke-na": {
      "options": {
        "args": [
          "--functionName=GetAllGamesSearchFunction"
        ]
      }
    }
  },
  "tags": [],
  "implicitDependencies": [],
  "version": "0.24.7",
  "dependencies": [
    "os-client"
  ]
}
