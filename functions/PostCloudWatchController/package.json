{
  "name": "post-cloud-watch-controller",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "MIT",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --sourcemap --minify --external:@aws-sdk/* --outfile=dist/index.js",
    "build:watch": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --sourcemap --external:@aws-sdk/* --outfile=dist/index.js --watch",
    "build:dev": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --sourcemap --external:@aws-sdk/* --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "local:dynamodb": "docker run --rm -p 8000:8000 -d amazon/dynamodb-local",
    "sam:build": "sam build",
    "sam:deploy": "sam deploy",
    "sam:local": "sam local invoke PostCloudWatchControllerFunction --env-vars env.eu.json",
    "unit": "jest",
    "test:e2e": "yarn build && node scripts/test-e2e.js",
    "clean": "rm -rf node_modules coverage",
    "clean:lock": "rimraf package-lock.json yarn.lock",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,json,md}'"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1020.0",
    "@aws-sdk/lib-dynamodb": "^3.1020.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "typescript": "^5.8.3"
  }
}
