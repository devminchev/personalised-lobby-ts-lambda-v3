{
  "$schema": "https://nx.dev/reference/project-configuration",
  "name": "post-cloud-watch-controller",
  "sourceRoot": "functions/PostCloudWatchController",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "options": {
        "outputPath": "dist/functions/PostCloudWatchControllerFunction",
        "main": "functions/PostCloudWatchController/src/index.ts",
        "tsConfig": "functions/PostCloudWatchController/tsconfig.json",
        "outputFileName": "index",
        "generatePackageJson": true
      },
      "configurations": {
        "production": {
          "configuration": "application"
        }
      }
    },
    "test": {},
    "lint": {},
    "format": {},
    "version": {},
    "changelog": {},
    "docker": {},
    "docker-push": {},
    "run-docker": {},
    "sam-invoke-eu": {
      "options": {
        "args": [
          "--functionName=PostCloudWatchControllerFunction"
        ]
      }
    },
    "sam-invoke-validate-eu": {}
  },
  "tags": [
    "type:app",
    "scope:pl"
  ],
  "dependencies": [],
  "version": "1.0.0"
}
